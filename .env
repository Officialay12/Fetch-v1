# ── SERVER ──
PORT=3001
NODE_ENV=development

# ── YOUR FRONTEND URL (set this after deploying to Vercel/Netlify) ──
# Example: https://fetch-app.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# ── YOUR FRONTEND DOMAIN (without https://) ──
# Example: fetch-app.vercel.app
FRONTEND_DOMAIN=your-frontend.vercel.app

# ── SECRET KEY for token signing ──
# Make this a long random string — keep it private, never share it
# Example: openssl rand -hex 32
API_SECRET=fetch-dev-secret-CHANGE-IN-PRODUCTION

# ── RAILWAY PROJECT (optional — helps CORS match your Vercel subdomains) ──
VERCEL_PROJECT=fetch-app
